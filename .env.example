# ─── Copie este arquivo para .env e preencha ───────────────────

# Modelo da LLM (formato: provider/modelo)
LLM_MODEL=seu-modelo-aqui

# Chave de API do provedor
API_KEY=sua_chave_aqui

# ID do usuário (define o arquivo de memória)
USER_ID=default

# Skills (opcional — pasta com arquivos .md)
SKILLS_DIR=./exemplo_skills/

# Contexto limitado (opcional — descomente para definir janela máxima)
# CONTEXT_SIZE=6

# Debug (opcional — mostra skills ativadas e execução detalhada)
# DEBUG=true
